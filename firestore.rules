rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    /**
     * LIFEOS SECURITY RULES
     * Ensures all data under a user's ID is only accessible by that user.
     * This recursive pattern is the most robust way to secure user silos.
     */
    match /users/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
